# ==============================================================================
# 【核心】C++ 编译产物（必忽略，避免仓库体积暴增）
# ==============================================================================
# 编译依赖文件
*.d
# 编译中间目标文件（不同编译器/系统的产物）
*.slo
*.lo
*.o
*.obj
# 预编译头文件（加速本地编译，无需同步）
*.gch
*.pch
# 链接器/调试文件
*.ilk
*.pdb
*.dwo
# 动态库/静态库文件
*.so
*.so.*
*.dylib
*.dll
*.lai
*.la
*.a
*.lib
# 可执行文件
*.exe
*.out
*.app
# 编译日志/临时产物
*.tmp
*.log
*.bak
*.swp

# ==============================================================================
# 【核心】CMake 相关文件（必忽略，避免协作冲突）
# ==============================================================================
# CMake 构建目录/自动生成文件
build/
Build/
build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json
# CTest 测试相关
Testing/
.cache/

# ==============================================================================
# VS Code 本地配置（必忽略，每个人的本地路径/配置不同）
# ==============================================================================
.vscode/launch.json
.vscode/tasks.json
.vscode/settings.json
.vscode/*.code-workspace
.vs/

# ==============================================================================
# 包管理/系统临时文件（可选但推荐）
# ==============================================================================
# vcpkg 依赖安装目录（如果用vcpkg）
vcpkg_installed/
# Windows 系统文件
Thumbs.db
Desktop.ini
# macOS 系统文件（跨平台开发需保留）
.DS_Store
._*
# 敏感信息文件（避免提交密码/密钥/本地路径）
*.local.h
.env
*.key